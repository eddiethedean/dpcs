{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "BindingFile": {
      "description": "A single generated orchestration artifact file.",
      "properties": {
        "content": {
          "description": "Full file contents.",
          "type": "string"
        },
        "mediaType": {
          "description": "IANA media type (for example `text/x-python` or `application/yaml`).",
          "type": "string"
        },
        "relativePath": {
          "description": "Path relative to the binding output root (POSIX-style separators).",
          "type": "string"
        }
      },
      "required": [
        "content",
        "mediaType",
        "relativePath"
      ],
      "type": "object"
    },
    "BindingTarget": {
      "description": "Supported orchestrator binding targets (ROADMAP 0.8.0).",
      "oneOf": [
        {
          "description": "Apache Airflow DAG scaffold.",
          "enum": [
            "airflow"
          ],
          "type": "string"
        },
        {
          "description": "Dagster Definitions / job scaffold.",
          "enum": [
            "dagster"
          ],
          "type": "string"
        },
        {
          "description": "Prefect flow scaffold.",
          "enum": [
            "prefect"
          ],
          "type": "string"
        },
        {
          "description": "Temporal workflow stub (experimental).",
          "enum": [
            "temporal"
          ],
          "type": "string"
        },
        {
          "description": "Kubernetes Job / CronJob manifests (experimental).",
          "enum": [
            "kubernetes"
          ],
          "type": "string"
        }
      ]
    },
    "CapabilityReport": {
      "description": "Structured capability evaluation report (ROADMAP “Capability reports”).",
      "properties": {
        "diagnostics": {
          "description": "Non-error diagnostics observed during evaluation (for example version warnings).\n\nOn CLI JSON failure paths, this may be replaced with the full diagnostic list.",
          "items": {
            "$ref": "#/definitions/Diagnostic"
          },
          "type": "array"
        },
        "missingMandatory": {
          "description": "Mandatory capability ids demanded by the plan but missing from the profile.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "planContractId": {
          "description": "Contract id from the plan when available.",
          "type": [
            "string",
            "null"
          ]
        },
        "profileIdentity": {
          "description": "Identity of the evaluated profile.",
          "type": "string"
        },
        "satisfied": {
          "description": "Capability ids demanded by the plan and satisfied by the profile.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "unsupportedOptional": {
          "description": "Profile capabilities marked `optional: true` that were not demanded.\n\nInformational only: these are unused optional supply, not SPEC “unsupported optional capabilities” that may be ignored on the demand side.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "missingMandatory",
        "profileIdentity",
        "satisfied",
        "unsupportedOptional"
      ],
      "type": "object"
    },
    "Diagnostic": {
      "description": "A single deterministic diagnostic observation.\n\nDiagnostics describe observations only and must not change pipeline semantics.",
      "properties": {
        "category": {
          "description": "Category of the observation.",
          "type": "string"
        },
        "id": {
          "description": "Stable diagnostic identifier (for example `DPCS-VAL-001`).",
          "type": "string"
        },
        "message": {
          "description": "Human-readable message.",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Implementation-specific metadata (string map).",
          "type": [
            "object",
            "null"
          ]
        },
        "objectRef": {
          "description": "Optional object reference within the contract.",
          "type": [
            "string",
            "null"
          ]
        },
        "relatedDiagnostics": {
          "description": "Related diagnostic identifiers.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "remediation": {
          "description": "Optional remediation guidance.",
          "type": [
            "string",
            "null"
          ]
        },
        "severity": {
          "allOf": [
            {
              "$ref": "#/definitions/Severity"
            }
          ],
          "description": "Severity of the observation."
        },
        "sourceLocation": {
          "description": "Optional source location in the original document.",
          "type": [
            "string",
            "null"
          ]
        },
        "stage": {
          "allOf": [
            {
              "$ref": "#/definitions/DiagnosticStage"
            }
          ],
          "description": "Processing stage that produced the diagnostic."
        }
      },
      "required": [
        "category",
        "id",
        "message",
        "severity",
        "stage"
      ],
      "type": "object"
    },
    "DiagnosticStage": {
      "description": "Stage of the DPCS processing pipeline that produced a diagnostic.",
      "oneOf": [
        {
          "description": "Document parsing.",
          "enum": [
            "parse"
          ],
          "type": "string"
        },
        {
          "description": "Canonical Object Model construction.",
          "enum": [
            "canonicalObjectModel"
          ],
          "type": "string"
        },
        {
          "description": "Semantic and structural validation.",
          "enum": [
            "validation"
          ],
          "type": "string"
        },
        {
          "description": "Compatibility analysis between artifacts.",
          "enum": [
            "compatibilityAnalysis"
          ],
          "type": "string"
        },
        {
          "description": "Pipeline plan generation.",
          "enum": [
            "planning"
          ],
          "type": "string"
        },
        {
          "description": "Orchestrator capability evaluation.",
          "enum": [
            "capabilityEvaluation"
          ],
          "type": "string"
        },
        {
          "description": "Orchestrator binding.",
          "enum": [
            "orchestratorBinding"
          ],
          "type": "string"
        },
        {
          "description": "Execution analysis (reserved; unused in 0.9.0 toolkit scope).",
          "enum": [
            "executionAnalysis"
          ],
          "type": "string"
        }
      ]
    },
    "Severity": {
      "description": "Severity of a diagnostic observation.",
      "oneOf": [
        {
          "description": "Informational observation that does not affect validity.",
          "enum": [
            "information"
          ],
          "type": "string"
        },
        {
          "description": "Non-fatal issue that should be reviewed.",
          "enum": [
            "warning"
          ],
          "type": "string"
        },
        {
          "description": "Error that makes the contract invalid.",
          "enum": [
            "error"
          ],
          "type": "string"
        }
      ]
    }
  },
  "description": "Bundle of platform-specific artifacts produced by a successful bind.",
  "properties": {
    "capability": {
      "allOf": [
        {
          "$ref": "#/definitions/CapabilityReport"
        }
      ],
      "description": "Capability match report from the pre-binding evaluation."
    },
    "contractId": {
      "description": "Source pipeline contract identifier.",
      "type": "string"
    },
    "contractVersion": {
      "description": "Source pipeline contract version.",
      "type": "string"
    },
    "files": {
      "description": "Generated artifact files.",
      "items": {
        "$ref": "#/definitions/BindingFile"
      },
      "type": "array"
    },
    "profileIdentity": {
      "description": "Capability profile identity used for the binding gate.",
      "type": "string"
    },
    "target": {
      "allOf": [
        {
          "$ref": "#/definitions/BindingTarget"
        }
      ],
      "description": "Target orchestrator adapter."
    }
  },
  "required": [
    "capability",
    "contractId",
    "contractVersion",
    "files",
    "profileIdentity",
    "target"
  ],
  "title": "BindingBundle",
  "type": "object"
}