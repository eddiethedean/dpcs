{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ConformanceLevel": {
      "description": "Conformance levels defined by SPEC Ch 23.",
      "oneOf": [
        {
          "description": "Parser conformance.",
          "enum": [
            "parser"
          ],
          "type": "string"
        },
        {
          "description": "Validator conformance.",
          "enum": [
            "validator"
          ],
          "type": "string"
        },
        {
          "description": "Planner conformance.",
          "enum": [
            "planner"
          ],
          "type": "string"
        },
        {
          "description": "Capability evaluator conformance.",
          "enum": [
            "capabilityEvaluator"
          ],
          "type": "string"
        },
        {
          "description": "Orchestrator binder conformance.",
          "enum": [
            "orchestratorBinder"
          ],
          "type": "string"
        },
        {
          "description": "Registry document conformance.",
          "enum": [
            "registry"
          ],
          "type": "string"
        },
        {
          "description": "Complete implementation conformance.",
          "enum": [
            "completeImplementation"
          ],
          "type": "string"
        }
      ]
    },
    "ExtensionValue": true
  },
  "description": "Explicit conformance claim for an implementation.",
  "properties": {
    "dpcsVersion": {
      "description": "Claimed DPCS specification version.",
      "type": "string"
    },
    "implementation": {
      "description": "Implementation name.",
      "type": "string"
    },
    "implementationVersion": {
      "description": "Implementation version.",
      "type": "string"
    },
    "levels": {
      "description": "Claimed levels.",
      "items": {
        "$ref": "#/definitions/ConformanceLevel"
      },
      "type": "array"
    }
  },
  "required": [
    "dpcsVersion",
    "implementation",
    "implementationVersion",
    "levels"
  ],
  "title": "ConformanceClaim",
  "type": "object"
}